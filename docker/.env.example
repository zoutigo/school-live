NODE_ENV=development

# API / DB
API_PORT=3001
DATABASE_URL=postgresql://school:school@localhost:5432/school_live?schema=public
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT / Auth backend
JWT_SECRET=change-me-super-secret
JWT_EXPIRES_IN=86400
JWT_REFRESH_EXPIRES_IN=2592000
JWT_REFRESH_TOKEN_PEPPER=change-me-refresh-pepper
PASSWORD_RESET_TOKEN_PEPPER=change-me-password-reset-pepper
ACTIVATION_CODE_PEPPER=change-me-activation-pepper
AUTH_RATE_LIMIT_PEPPER=change-me-auth-rate-limit-pepper
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_BLOCK_SECONDS=900
ACTIVATION_CODE_TTL_HOURS=48

# Redis / Worker
REDIS_URL=redis://localhost:6379

# Media service
MEDIA_SERVICE_URL=http://localhost:3002
MEDIA_INTERNAL_TOKEN=change-me-media-token
MOBILE_BUILD_UPLOAD_TOKEN=change-me-mobile-build-upload-token
MEDIA_PORT=3002
MEDIA_S3_ENDPOINT=http://localhost:9000
MEDIA_S3_REGION=af-south-1
MEDIA_S3_ACCESS_KEY=minioadmin
MEDIA_S3_SECRET_KEY=minioadmin
MEDIA_S3_BUCKET=school-live-media
MEDIA_PUBLIC_BASE_URL=http://localhost:9000/school-live-media
INLINE_MEDIA_TEMP_TTL_MINUTES=1440

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=info@example.com
SMTP_PASS=change-me
SMTP_SECURE=true
MAIL_FROM=info@example.com

# NextAuth / Web
NEXT_PUBLIC_API_URL=http://localhost:3001/api
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=change-me-nextauth-secret
NEXTAUTH_SECRET=change-me-nextauth-secret
AUTH_VERBOSE=true

# Google OAuth
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# Apple OAuth (optionnel)
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# MinIO root (docker-compose.vps.yml)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Infra
UPLOADS_ROOT=/home/ubuntu/uploads/scolive
NGINX_NETWORK=proxy
