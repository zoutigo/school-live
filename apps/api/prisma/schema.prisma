generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  SUPER_ADMIN
  ADMIN
  SALES
  SUPPORT
}

enum SchoolRole {
  SCHOOL_ADMIN
  SCHOOL_MANAGER
  SUPERVISOR
  SCHOOL_ACCOUNTANT
  SCHOOL_STAFF
  TEACHER
  PARENT
  STUDENT
}

enum AppRole {
  SUPER_ADMIN
  ADMIN
  SALES
  SUPPORT
  SCHOOL_ADMIN
  SCHOOL_MANAGER
  SUPERVISOR
  SCHOOL_ACCOUNTANT
  SCHOOL_STAFF
  TEACHER
  PARENT
  STUDENT
}

enum Gender {
  M
  F
  OTHER
}

enum AccountActivationStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum AuthProvider {
  GOOGLE
  APPLE
}

enum AuthRateLimitPurpose {
  PASSWORD_LOGIN
  PHONE_LOGIN
  SSO_LOGIN
  ACTIVATION
}

enum AuthAuditEvent {
  LOGIN_PASSWORD
  LOGIN_PHONE
  LOGIN_SSO
  ACTIVATION_COMPLETE
  CHANGE_PASSWORD
  CHANGE_PIN
  CREATE_PASSWORD
  ADD_EMAIL
  VERIFY_EMAIL
  ADD_PHONE_CREDENTIAL
}

enum AuthAuditStatus {
  SUCCESS
  FAILURE
  BLOCKED
}

enum RecoveryQuestionKey {
  MOTHER_MAIDEN_NAME
  FATHER_FIRST_NAME
  FAVORITE_SPORT
  FAVORITE_TEACHER
  BIRTH_CITY
  CHILDHOOD_NICKNAME
  FAVORITE_BOOK
}

enum Term {
  TERM_1
  TERM_2
  TERM_3
}

enum EnrollmentStatus {
  ACTIVE
  TRANSFERRED
  WITHDRAWN
  GRADUATED
}

enum OverrideAction {
  ADD
  REMOVE
}

enum StudentLifeEventType {
  ABSENCE
  RETARD
  SANCTION
  PUNITION
}

enum SchoolCalendarEventType {
  HOLIDAY
}

enum SchoolCalendarEventScope {
  SCHOOL
  ACADEMIC_LEVEL
  CLASS
}

enum TimetableOccurrenceExceptionType {
  OVERRIDE
  CANCEL
}

enum TimetableOccurrenceStatus {
  PLANNED
  CANCELLED
}

enum InternalMessageStatus {
  DRAFT
  SENT
}

enum FeedPostType {
  POST
  POLL
}

enum FeedAudienceScope {
  SCHOOL_ALL
  STAFF_ONLY
  PARENTS_STUDENTS
  PARENTS_ONLY
  LEVEL
  CLASS
}

enum InlineMediaScope {
  FEED
  MESSAGING
}

enum InlineMediaStatus {
  TEMP
  LINKED
}

enum InlineMediaEntityType {
  FEED_POST
  INTERNAL_MESSAGE
}

enum EvaluationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EvaluationScoreStatus {
  ENTERED
  ABSENT
  EXCUSED
  NOT_GRADED
}

enum EvaluationAuditAction {
  CREATED
  UPDATED
  PUBLISHED
  SCORES_UPDATED
}

enum TermReportStatus {
  DRAFT
  PUBLISHED
}

enum TicketType {
  BUG
  FEATURE_REQUEST
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ANSWERED
  RESOLVED
  CLOSED
}

enum HelpGuideAudience {
  PARENT
  TEACHER
  STUDENT
  SCHOOL_ADMIN
  STAFF
}

enum HelpPublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum HelpChapterContentType {
  RICH_TEXT
  VIDEO
}


model School {
  id                 String                @id @default(cuid())
  slug               String                @unique
  name               String
  country            String?
  region             String?
  city               String?
  logoUrl            String?
  primaryColor       String?
  activeSchoolYearId String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  activeSchoolYear   SchoolYear?           @relation("ActiveSchoolYear", fields: [activeSchoolYearId], references: [id], onDelete: SetNull)
  schoolYears        SchoolYear[]          @relation("SchoolYears")
  memberships        SchoolMembership[]
  classGroups        ClassGroup[]
  students           Student[]
  teachers           Teacher[]
  classes            Class[]
  subjects           Subject[]
  subjectBranches    SubjectBranch[]
  assignments        TeacherClassSubject[]
  studentGrades      StudentGrade[]
  evaluationTypes    EvaluationType[]
  evaluations        Evaluation[]
  evaluationAttachments EvaluationAttachment[]
  evaluationAuditLogs EvaluationAuditLog[]
  studentTermReports StudentTermReport[]
  studentTermReportEntries StudentTermReportEntry[]
  enrollments        Enrollment[]
  classSubjectOverrides ClassSubjectOverride[]
  academicLevels     AcademicLevel[]
  tracks             Track[]
  curriculums        Curriculum[]
  curriculumSubjects CurriculumSubject[]
  lifeEvents         StudentLifeEvent[]
  staffFunctions     SchoolStaffFunction[]
  staffAssignments   SchoolStaffAssignment[]
  internalMessages   InternalMessage[]
  messageRecipients  InternalMessageRecipient[]
  messageAttachments InternalMessageAttachment[]
  feedPosts          FeedPost[]
  feedComments       FeedComment[]
  feedLikes          FeedLike[]
  feedPollVotes      FeedPollVote[]
  activationCodes    ActivationCode[]
  authAuditLogs      AuthAuditLog[]
  timetableSlots     ClassTimetableSlot[]
  timetableOneOffSlots ClassTimetableOneOffSlot[]
  timetableSlotExceptions ClassTimetableSlotException[]
  timetableSubjectStyles ClassTimetableSubjectStyle[]
  calendarEvents     SchoolCalendarEvent[]
  tickets            Ticket[]
  helpGuides         HelpGuide[]

  @@index([activeSchoolYearId])
}

model User {
  id                 String                   @id @default(cuid())
  email              String?                  @unique
  phone              String?
  phoneConfirmedAt   DateTime?
  avatarUrl          String?
  passwordHash       String?
  mustChangePassword Boolean                  @default(false)
  profileCompleted   Boolean                  @default(true)
  activationStatus   AccountActivationStatus  @default(ACTIVE)
  activeRole         AppRole?
  recoveryBirthDate  DateTime?
  recoveryClassId    String?
  recoveryStudentId  String?
  firstName          String                   @map("firstname")
  lastName           String                   @map("lastname")
  gender             Gender?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  platformRoles      PlatformRoleAssignment[]
  memberships        SchoolMembership[]
  teacherProfiles    Teacher[]
  studentProfiles    Student[]
  parentLinks        ParentStudent[]          @relation("ParentLinks")
  studentGradesGiven StudentGrade[]           @relation("StudentGradeTeacher")
  evaluationsAuthored Evaluation[]            @relation("EvaluationAuthor")
  evaluationAuditLogs EvaluationAuditLog[]    @relation("EvaluationAuditActor")
  studentTermReportsAuthored StudentTermReport[] @relation("StudentTermReportUpdatedBy")
  studentTermReportEntriesAuthored StudentTermReportEntry[] @relation("StudentTermReportEntryUpdatedBy")
  teachingAssignments TeacherClassSubject[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  recoveryAnswers    UserRecoveryAnswer[]
  authIdentities     UserAuthIdentity[]
  phoneCredential    UserPhoneCredential?
  emailVerificationTokens EmailVerificationToken[]
  activationCodes    ActivationCode[]         @relation("ActivationCodeUser")
  createdActivationCodes ActivationCode[]     @relation("ActivationCodeIssuer")
  authAuditLogs      AuthAuditLog[]
  lifeEventsAuthored StudentLifeEvent[]       @relation("LifeEventAuthor")
  staffAssignments   SchoolStaffAssignment[]
  sentMessages       InternalMessage[]         @relation("InternalMessageSender")
  receivedMessages   InternalMessageRecipient[] @relation("InternalMessageRecipientUser")
  feedPosts          FeedPost[]                @relation("FeedPostAuthor")
  feedComments       FeedComment[]             @relation("FeedCommentAuthor")
  feedLikes          FeedLike[]                @relation("FeedLikeUser")
  feedPollVotes      FeedPollVote[]            @relation("FeedPollVoteUser")
  referentOfClasses  Class[]                   @relation("ClassReferentTeacher")
  timetableSlotsAsTeacher ClassTimetableSlot[] @relation("ClassTimetableSlotTeacher")
  timetableSlotsCreated ClassTimetableSlot[]   @relation("ClassTimetableSlotCreatedBy")
  timetableOneOffSlotsAsTeacher ClassTimetableOneOffSlot[] @relation("ClassTimetableOneOffSlotTeacher")
  timetableOneOffSlotsCreated ClassTimetableOneOffSlot[]   @relation("ClassTimetableOneOffSlotCreatedBy")
  timetableSlotExceptionsAsTeacher ClassTimetableSlotException[] @relation("ClassTimetableSlotExceptionTeacher")
  timetableSlotExceptionsCreated ClassTimetableSlotException[] @relation("ClassTimetableSlotExceptionCreatedBy")
  calendarEventsCreated SchoolCalendarEvent[]  @relation("SchoolCalendarEventCreatedBy")
  tickets               Ticket[]               @relation("TicketAuthor")
  ticketResponses       TicketResponse[]        @relation("TicketResponseAuthor")
  ticketVotes           TicketVote[]            @relation("TicketVoter")
  helpGuidesCreated     HelpGuide[]             @relation("HelpGuideCreatedBy")
  helpGuidesUpdated     HelpGuide[]             @relation("HelpGuideUpdatedBy")
  helpChaptersCreated   HelpChapter[]           @relation("HelpChapterCreatedBy")
  helpChaptersUpdated   HelpChapter[]           @relation("HelpChapterUpdatedBy")
}

model UserAuthIdentity {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  email             String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([email])
}

model UserPhoneCredential {
  id         String   @id @default(cuid())
  userId     String   @unique
  phoneE164  String   @unique
  pinHash    String
  verifiedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneE164])
}

model ActivationCode {
  id              String   @id @default(cuid())
  userId          String
  schoolId        String
  codeHash        String
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime @default(now())
  createdByUserId String?
  user            User     @relation("ActivationCodeUser", fields: [userId], references: [id], onDelete: Cascade)
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdByUser   User?    @relation("ActivationCodeIssuer", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([schoolId])
  @@index([expiresAt])
  @@index([usedAt])
}

model AuthRateLimit {
  id          String               @id @default(cuid())
  purpose     AuthRateLimitPurpose
  keyHash     String
  failedCount Int                  @default(0)
  blockedUntil DateTime?
  lastFailedAt DateTime?
  lastSuccessAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([purpose, keyHash])
  @@index([blockedUntil])
}

model AuthAuditLog {
  id         String          @id @default(cuid())
  userId     String?
  schoolId   String?
  event      AuthAuditEvent
  status     AuthAuditStatus
  provider   AuthProvider?
  principal  String?
  ipAddress  String?
  userAgent  String?
  reasonCode String?
  details    Json?
  createdAt  DateTime        @default(now())
  user       User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  school     School?         @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([schoolId])
  @@index([event, status, createdAt])
}

model PlatformRoleAssignment {
  id        String       @id @default(cuid())
  userId    String
  role      PlatformRole
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
}

model SchoolMembership {
  id        String    @id @default(cuid())
  userId    String
  schoolId  String
  role      SchoolRole
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId, role])
  @@index([schoolId])
  @@index([role])
}

model SchoolStaffFunction {
  id          String                 @id @default(cuid())
  schoolId    String
  name        String
  description String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  school      School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignments SchoolStaffAssignment[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model SchoolStaffAssignment {
  id         String             @id @default(cuid())
  schoolId   String
  functionId String
  userId     String
  createdAt  DateTime           @default(now())
  school     School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  function   SchoolStaffFunction @relation(fields: [functionId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, functionId, userId])
  @@index([schoolId])
  @@index([functionId])
  @@index([userId])
}

model RefreshToken {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}


model Student {
  id          String          @id @default(cuid())
  schoolId    String
  userId      String?
  firstName   String
  lastName    String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  school      School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  parentLinks ParentStudent[] @relation("StudentLinks")
  studentGrades StudentGrade[]
  evaluationScores StudentEvaluationScore[]
  termReports   StudentTermReport[]
  enrollments Enrollment[]
  lifeEvents  StudentLifeEvent[]

  @@index([schoolId])
  @@unique([schoolId, userId])
}

model Enrollment {
  id           String           @id @default(cuid())
  schoolId     String
  schoolYearId String
  studentId    String
  classId      String
  status       EnrollmentStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  school       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolYear   SchoolYear       @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class        Class            @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([schoolYearId, studentId])
  @@index([schoolId])
  @@index([schoolYearId])
  @@index([classId])
  @@index([studentId])
}

model ParentStudent {
  id           String   @id @default(cuid())
  schoolId     String
  parentUserId String
  studentId    String
  createdAt    DateTime @default(now())
  parent       User     @relation("ParentLinks", fields: [parentUserId], references: [id], onDelete: Cascade)
  student      Student  @relation("StudentLinks", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentUserId, studentId])
  @@index([schoolId])
  @@index([studentId])
}

model Teacher {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@unique([schoolId, userId])
}

model UserRecoveryAnswer {
  id          String              @id @default(cuid())
  userId      String
  questionKey RecoveryQuestionKey
  answerHash  String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionKey])
  @@index([userId])
}


model ClassGroup {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes   Class[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model SchoolYear {
  id                  String                @id @default(cuid())
  schoolId            String
  label               String
  startsAt            DateTime?
  endsAt              DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  school              School                @relation("SchoolYears", fields: [schoolId], references: [id], onDelete: Cascade)
  activeForSchools    School[]              @relation("ActiveSchoolYear")
  classes             Class[]
  enrollments         Enrollment[]
  teachingAssignments TeacherClassSubject[]
  studentGrades       StudentGrade[]
  evaluations         Evaluation[]
  termReports         StudentTermReport[]
  lifeEvents          StudentLifeEvent[]
  timetableSlots      ClassTimetableSlot[]
  timetableOneOffSlots ClassTimetableOneOffSlot[]
  timetableSlotExceptions ClassTimetableSlotException[]
  timetableSubjectStyles ClassTimetableSubjectStyle[]
  calendarEvents      SchoolCalendarEvent[]

  @@unique([schoolId, label])
  @@index([schoolId])
}

model AcademicLevel {
  id          String       @id @default(cuid())
  schoolId    String
  code        String
  label       String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes     Class[]
  feedPosts   FeedPost[]
  curriculums Curriculum[]
  calendarEvents SchoolCalendarEvent[]

  @@unique([schoolId, code])
  @@index([schoolId])
}

model Track {
  id          String       @id @default(cuid())
  schoolId    String
  code        String
  label       String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes     Class[]
  curriculums Curriculum[]

  @@unique([schoolId, code])
  @@index([schoolId])
}

model Curriculum {
  id              String              @id @default(cuid())
  schoolId        String
  name            String
  academicLevelId String
  trackId         String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  school          School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicLevel   AcademicLevel       @relation(fields: [academicLevelId], references: [id], onDelete: Cascade)
  track           Track?              @relation(fields: [trackId], references: [id], onDelete: SetNull)
  classes         Class[]
  subjects        CurriculumSubject[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([academicLevelId])
  @@index([trackId])
}

model CurriculumSubject {
  id           String     @id @default(cuid())
  schoolId     String
  curriculumId String
  subjectId    String
  isMandatory  Boolean    @default(true)
  coefficient  Float?
  weeklyHours  Float?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  subject      Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([curriculumId, subjectId])
  @@index([schoolId])
  @@index([subjectId])
}

model Class {
  id              String                @id @default(cuid())
  schoolId        String
  schoolYearId    String
  classGroupId    String?
  academicLevelId String?
  trackId         String?
  curriculumId    String?
  referentTeacherUserId String?
  name            String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  school          School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolYear      SchoolYear            @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  classGroup      ClassGroup?           @relation(fields: [classGroupId], references: [id], onDelete: SetNull)
  academicLevel   AcademicLevel?        @relation(fields: [academicLevelId], references: [id], onDelete: SetNull)
  track           Track?                @relation(fields: [trackId], references: [id], onDelete: SetNull)
  curriculum      Curriculum?           @relation(fields: [curriculumId], references: [id], onDelete: SetNull)
  referentTeacher User?                 @relation("ClassReferentTeacher", fields: [referentTeacherUserId], references: [id], onDelete: SetNull)
  enrollments     Enrollment[]
  assignments     TeacherClassSubject[]
  studentGrades   StudentGrade[]
  evaluations     Evaluation[]
  termReports     StudentTermReport[]
  subjectOverrides ClassSubjectOverride[]
  lifeEvents      StudentLifeEvent[]
  feedPosts       FeedPost[]
  timetableSlots  ClassTimetableSlot[]
  timetableOneOffSlots ClassTimetableOneOffSlot[]
  timetableSlotExceptions ClassTimetableSlotException[]
  timetableSubjectStyles ClassTimetableSubjectStyle[]
  calendarEvents  SchoolCalendarEvent[]

  @@unique([schoolId, schoolYearId, classGroupId, name])
  @@index([schoolId])
  @@index([schoolYearId])
  @@index([classGroupId])
  @@index([academicLevelId])
  @@index([trackId])
  @@index([curriculumId])
  @@index([referentTeacherUserId])
}

model Subject {
  id           String                @id @default(cuid())
  schoolId     String
  name         String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  school       School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignments  TeacherClassSubject[]
  studentGrades StudentGrade[]
  branches     SubjectBranch[]
  evaluations  Evaluation[]
  termReportEntries StudentTermReportEntry[]
  curriculumSubjects CurriculumSubject[]
  classOverrides ClassSubjectOverride[]
  timetableSlots ClassTimetableSlot[]
  timetableOneOffSlots ClassTimetableOneOffSlot[]
  timetableSlotExceptions ClassTimetableSlotException[]
  timetableSubjectStyles ClassTimetableSubjectStyle[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ClassSubjectOverride {
  id                    String         @id @default(cuid())
  schoolId              String
  classId               String
  subjectId             String
  action                OverrideAction
  coefficientOverride   Float?
  weeklyHoursOverride   Float?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  school                School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class                 Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject               Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId])
  @@index([schoolId])
  @@index([classId])
  @@index([subjectId])
}

model TeacherClassSubject {
  id            String     @id @default(cuid())
  schoolId      String
  schoolYearId  String
  teacherUserId String
  classId       String
  subjectId     String
  createdAt     DateTime   @default(now())
  school        School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolYear    SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  teacherUser   User       @relation(fields: [teacherUserId], references: [id], onDelete: Cascade)
  class         Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject       Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([schoolYearId, teacherUserId, classId, subjectId])
  @@index([schoolId])
  @@index([schoolYearId])
  @@index([classId])
  @@index([subjectId])
}


model ClassTimetableSlot {
  id              String    @id @default(cuid())
  schoolId        String
  schoolYearId    String
  classId         String
  subjectId       String
  teacherUserId   String
  weekday         Int
  startMinute     Int
  endMinute       Int
  activeFromDate  DateTime?
  activeToDate    DateTime?
  room            String?
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolYear      SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  class           Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject         Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherUser     User      @relation("ClassTimetableSlotTeacher", fields: [teacherUserId], references: [id], onDelete: Cascade)
