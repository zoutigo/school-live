}

enum RecoveryQuestionKey {
  MOTHER_MAIDEN_NAME
  FATHER_FIRST_NAME
  FAVORITE_SPORT
  FAVORITE_TEACHER
  BIRTH_CITY
  CHILDHOOD_NICKNAME
  FAVORITE_BOOK
}

enum Term {
  TERM_1
  TERM_2
  TERM_3
}

enum EnrollmentStatus {
  ACTIVE
  TRANSFERRED
  WITHDRAWN
  GRADUATED
}

enum OverrideAction {
  ADD
  REMOVE
}

enum StudentLifeEventType {
  ABSENCE
  RETARD
  SANCTION
  PUNITION
}

enum SchoolCalendarEventType {
  HOLIDAY
}

enum SchoolCalendarEventScope {
  SCHOOL
  ACADEMIC_LEVEL
  CLASS
}

enum TimetableOccurrenceExceptionType {
  OVERRIDE
  CANCEL
}

enum TimetableOccurrenceStatus {
  PLANNED
  CANCELLED
}

enum InternalMessageStatus {
  DRAFT
  SENT
}

enum FeedPostType {
  POST
  POLL
}

enum FeedAudienceScope {
  SCHOOL_ALL
  STAFF_ONLY
