  CLASS
}

enum InlineMediaScope {
  FEED
  MESSAGING
}

enum InlineMediaStatus {
  TEMP
  LINKED
}

enum InlineMediaEntityType {
  FEED_POST
  INTERNAL_MESSAGE
}

enum EvaluationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EvaluationScoreStatus {
  ENTERED
  ABSENT
  EXCUSED
  NOT_GRADED
}

enum EvaluationAuditAction {
  CREATED
  UPDATED
  PUBLISHED
  SCORES_UPDATED
}

enum TermReportStatus {
  DRAFT
  PUBLISHED
}
