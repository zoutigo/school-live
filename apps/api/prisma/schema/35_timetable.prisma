model ClassTimetableSlot {
  id              String    @id @default(cuid())
  schoolId        String
  schoolYearId    String
  classId         String
  subjectId       String
  teacherUserId   String
  weekday         Int
  startMinute     Int
  endMinute       Int
  activeFromDate  DateTime?
  activeToDate    DateTime?
  room            String?
  roomId          String?
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolYear      SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  class           Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject         Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherUser     User      @relation("ClassTimetableSlotTeacher", fields: [teacherUserId], references: [id], onDelete: Cascade)
  createdByUser   User      @relation("ClassTimetableSlotCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  roomRef         Room?     @relation("ClassTimetableSlotRoom", fields: [roomId], references: [id], onDelete: SetNull)
  exceptions      ClassTimetableSlotException[]
  oneOffSlots     ClassTimetableOneOffSlot[] @relation("ClassTimetableOneOffSourceSlot")

  @@index([schoolId])
  @@index([schoolYearId])
  @@index([classId, weekday, startMinute, activeFromDate, activeToDate])
  @@index([teacherUserId, weekday, startMinute, activeFromDate, activeToDate])
  @@index([room, weekday, startMinute, activeFromDate, activeToDate])
  @@index([roomId, weekday, startMinute, activeFromDate, activeToDate])
}

model ClassTimetableOneOffSlot {
  id              String                   @id @default(cuid())
  schoolId        String
  schoolYearId    String
  classId         String
  subjectId       String
  teacherUserId   String
  occurrenceDate  DateTime
  startMinute     Int
  endMinute       Int
  room            String?
  roomId          String?
  status          TimetableOccurrenceStatus @default(PLANNED)
  sourceSlotId    String?
  createdByUserId String
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  school          School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolYear      SchoolYear               @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  class           Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject         Subject                  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherUser     User                     @relation("ClassTimetableOneOffSlotTeacher", fields: [teacherUserId], references: [id], onDelete: Cascade)
  sourceSlot      ClassTimetableSlot?      @relation("ClassTimetableOneOffSourceSlot", fields: [sourceSlotId], references: [id], onDelete: SetNull)
  createdByUser   User                     @relation("ClassTimetableOneOffSlotCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  roomRef         Room?                    @relation("ClassTimetableOneOffSlotRoom", fields: [roomId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([schoolYearId])
  @@index([classId, occurrenceDate, startMinute])
  @@index([teacherUserId, occurrenceDate, startMinute])
  @@index([room, occurrenceDate, startMinute])
  @@index([roomId, occurrenceDate, startMinute])
}

model ClassTimetableSlotException {
  id              String                          @id @default(cuid())
  schoolId        String
  schoolYearId    String
  classId         String
  slotId          String
  occurrenceDate  DateTime
  type            TimetableOccurrenceExceptionType
  subjectId       String?
  teacherUserId   String?
  startMinute     Int?
  endMinute       Int?
  room            String?
  roomId          String?
  reason          String?
  createdByUserId String
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  school          School                          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolYear      SchoolYear                      @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  class           Class                           @relation(fields: [classId], references: [id], onDelete: Cascade)
  slot            ClassTimetableSlot              @relation(fields: [slotId], references: [id], onDelete: Cascade)
  subject         Subject?                        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  teacherUser     User?                           @relation("ClassTimetableSlotExceptionTeacher", fields: [teacherUserId], references: [id], onDelete: SetNull)
  createdByUser   User                            @relation("ClassTimetableSlotExceptionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  roomRef         Room?                           @relation("ClassTimetableSlotExceptionRoom", fields: [roomId], references: [id], onDelete: SetNull)

  @@unique([slotId, occurrenceDate])
  @@index([schoolId])
  @@index([schoolYearId])
  @@index([classId, occurrenceDate])
  @@index([teacherUserId, occurrenceDate, startMinute])
  @@index([room, occurrenceDate, startMinute])
  @@index([roomId, occurrenceDate, startMinute])
}

model ClassTimetableSubjectStyle {
  id          String   @id @default(cuid())
  schoolId    String
  schoolYearId String
  classId     String
  subjectId   String
  colorHex    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolYear  SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([schoolId, schoolYearId, classId, subjectId])
  @@index([schoolId, schoolYearId, classId])
  @@index([subjectId])
}

model SchoolCalendarEvent {
  id              String                  @id @default(cuid())
  schoolId        String
  schoolYearId    String
  type            SchoolCalendarEventType @default(HOLIDAY)
  scope           SchoolCalendarEventScope
  label           String
  startDate       DateTime
  endDate         DateTime
  academicLevelId String?
  classId         String?
  createdByUserId String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  school          School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolYear      SchoolYear              @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  academicLevel   AcademicLevel?          @relation(fields: [academicLevelId], references: [id], onDelete: SetNull)
  class           Class?                  @relation(fields: [classId], references: [id], onDelete: SetNull)
  createdByUser   User                    @relation("SchoolCalendarEventCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([schoolYearId])
  @@index([scope, classId, academicLevelId])
  @@index([startDate, endDate])
}

model Room {
  id                 String     @id @default(cuid())
  schoolId           String
  name               String
  description        String?
  capacity           Int?
  maxConcurrentSlots Int        @default(1)
  status             RoomStatus @default(AVAILABLE)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  school             School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  slots              ClassTimetableSlot[] @relation("ClassTimetableSlotRoom")
  oneOffSlots        ClassTimetableOneOffSlot[] @relation("ClassTimetableOneOffSlotRoom")
  slotExceptions     ClassTimetableSlotException[] @relation("ClassTimetableSlotExceptionRoom")

  @@unique([schoolId, name])
  @@index([schoolId])
}
