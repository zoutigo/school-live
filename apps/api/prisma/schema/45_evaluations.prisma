model SubjectBranch {
  id          String   @id @default(cuid())
  schoolId    String
  subjectId   String
  name        String
  code        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  evaluations Evaluation[]

  @@unique([subjectId, name])
  @@index([schoolId])
  @@index([subjectId])
}

model EvaluationType {
  id          String   @id @default(cuid())
  schoolId    String
  code        String
  label       String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  evaluations Evaluation[]

  @@unique([schoolId, code])
  @@unique([schoolId, label])
  @@index([schoolId])
}

model Evaluation {
  id               String            @id @default(cuid())
  schoolId         String
  schoolYearId     String
  classId          String
  subjectId        String
  subjectBranchId  String?
  evaluationTypeId String
  authorUserId     String
  title            String
  description      String?
  coefficient      Float             @default(1)
  maxScore         Float
  term             Term
  status           EvaluationStatus  @default(DRAFT)
  scheduledAt      DateTime?
  publishedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  school           School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolYear       SchoolYear        @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  class            Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject          Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectBranch    SubjectBranch?    @relation(fields: [subjectBranchId], references: [id], onDelete: SetNull)
  evaluationType   EvaluationType    @relation(fields: [evaluationTypeId], references: [id], onDelete: Restrict)
  authorUser       User              @relation("EvaluationAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  attachments      EvaluationAttachment[]
  scores           StudentEvaluationScore[]
  auditLogs        EvaluationAuditLog[]

  @@index([schoolId])
  @@index([schoolYearId])
  @@index([classId, subjectId, term, createdAt])
  @@index([subjectBranchId])
  @@index([evaluationTypeId])
  @@index([authorUserId])
}

model EvaluationAttachment {
  id           String     @id @default(cuid())
  schoolId     String
  evaluationId String
  fileName     String
  fileUrl      String?
  sizeLabel    String?
  mimeType     String?
  createdAt    DateTime   @default(now())
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([evaluationId])
}

model StudentEvaluationScore {
  id           String                @id @default(cuid())
  evaluationId String
  studentId    String
  score        Float?
  comment      String?
  status       EvaluationScoreStatus @default(ENTERED)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  evaluation   Evaluation            @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  student      Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, studentId])
  @@index([studentId])
  @@index([evaluationId, status])
}

model EvaluationAuditLog {
  id           String                @id @default(cuid())
  schoolId     String
  evaluationId String
  actorUserId  String
  action       EvaluationAuditAction
  payloadJson  Json?
  createdAt    DateTime              @default(now())
  school       School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  evaluation   Evaluation            @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  actorUser    User                  @relation("EvaluationAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([evaluationId, createdAt])
  @@index([actorUserId])
}

model StudentTermReport {
  id                 String           @id @default(cuid())
  schoolId           String
  schoolYearId       String
  classId            String
  studentId          String
  term               Term
  status             TermReportStatus @default(DRAFT)
  councilHeldAt      DateTime?
  generalAppreciation String?
  publishedAt        DateTime?
  updatedByUserId    String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  school             School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolYear         SchoolYear       @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  class              Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  student            Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  updatedByUser      User             @relation("StudentTermReportUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Cascade)
  subjectEntries     StudentTermReportEntry[]

  @@unique([schoolYearId, classId, studentId, term])
  @@index([schoolId])
  @@index([classId, term])
  @@index([studentId, term])
  @@index([updatedByUserId])
}

model StudentTermReportEntry {
  id                String            @id @default(cuid())
  schoolId          String
  reportId          String
  subjectId         String
  appreciation      String
  updatedByUserId   String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  report            StudentTermReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  subject           Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  updatedByUser     User              @relation("StudentTermReportEntryUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Cascade)

  @@unique([reportId, subjectId])
  @@index([schoolId])
  @@index([reportId])
  @@index([subjectId])
  @@index([updatedByUserId])
}
